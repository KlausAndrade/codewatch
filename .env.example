# LLM Provider (google, openai, or groq)
# CODEWATCH_LLM_PROVIDER=google
# CODEWATCH_FALLBACK_PROVIDER=openai
# CODEWATCH_GOOGLE_MODEL=gemini-2.5-flash
# CODEWATCH_OPENAI_MODEL=gpt-4o-mini
# CODEWATCH_GROQ_MODEL=llama-3.3-70b-versatile

# API Keys (set at least one)
# GOOGLE_GENERATIVE_AI_API_KEY=your-key-here
# OPENAI_API_KEY=your-key-here
# GROQ_API_KEY=your-key-here

# Storage
# CODEWATCH_DATA_DIR=~/mcp-data/codewatch-memory

# Thresholds (tokens)
# CODEWATCH_REFLECT_THRESHOLD=40000

# Auto-reflect when observations exceed threshold
# CODEWATCH_AUTO_REFLECT=true

# Project directory (auto-detected if not set)
# CODEWATCH_PROJECT_DIR=/path/to/project

# Logging
# CODEWATCH_LOG_LEVEL=info
